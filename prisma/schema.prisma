generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// One row per Plaid Item (one bank login can cover multiple accounts)
model PlaidItem {
  id              String    @id @default(cuid())
  itemId          String    @unique
  accessToken     String // Plaid access_token. This app is single-user/self-hosted; treat DATABASE_URL access as sensitive.
  institutionId   String?
  institutionName String?
  transactionsCursor String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  accounts        Account[]
}

enum AccountType {
  checking
  savings
  credit_card
  loan
  investment
  other
}

model Account {
  id               String        @id @default(cuid())
  name             String
  officialName     String?
  institutionName  String?
  type             AccountType
  subtype          String?
  mask             String?
  currentBalance   Float         @default(0)
  availableBalance Float?
  creditLimit      Float?
  isManual         Boolean       @default(true)
  plaidAccountId   String?       @unique
  plaidItemId      String?
  plaidItem        PlaidItem?    @relation(fields: [plaidItemId], references: [id], onDelete: SetNull)
  transactions     Transaction[]
  bills            Bill[]
  goals            Goal[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Transaction {
  id                  String   @id @default(cuid())
  accountId            String
  account               Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  plaidTransactionId   String?  @unique
  name                 String
  merchantName         String?
  amount               Float // positive = money out, negative = money in (Plaid convention)
  isoCurrencyCode      String   @default("USD")
  category             String? // primary category name (kept in sync with categoryId for back-compat)
  subcategory          String?
  categoryId           String? // link to the Category model (optional, richer)
  categoryRef          Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date                 DateTime
  pending              Boolean  @default(false)
  isRecurring          Boolean  @default(false)
  reviewed             Boolean  @default(false)
  notes                String?
  createdAt            DateTime @default(now())

  tags                TransactionTag[]
  splits              TransactionSplit[]

  @@index([accountId])
  @@index([date])
  @@index([category])
  @@index([categoryId])
  @@index([reviewed])
}

// ---- Category model (Phase 1: Monarch-style categories & groups) ----

enum CategoryType {
  income
  expense
  transfer
}

model CategoryGroup {
  id         String       @id @default(cuid())
  name       String
  type       CategoryType @default(expense)
  sortOrder  Int          @default(0)
  isSystem   Boolean      @default(false)
  categories Category[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Category {
  id                String       @id @default(cuid())
  groupId           String
  group             CategoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name              String
  emoji             String?
  type              CategoryType @default(expense)
  rollover          Boolean      @default(false)
  excludeFromBudget Boolean      @default(false)
  sortOrder         Int          @default(0)
  isSystem          Boolean      @default(false)
  transactions      Transaction[]
  splits            TransactionSplit[]
  budgets           Budget[]
  rules             TransactionRule[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([groupId])
}

model Tag {
  id           String           @id @default(cuid())
  name         String           @unique
  color        String           @default("#3b82f6")
  transactions TransactionTag[]
  createdAt    DateTime         @default(now())
}

model TransactionTag {
  id            String      @id @default(cuid())
  transactionId String
  tagId         String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([transactionId, tagId])
  @@index([tagId])
}

model TransactionRule {
  id          String    @id @default(cuid())
  name        String?
  matchField  String    @default("name") // name | merchantName | category
  matchType   String    @default("contains") // contains | equals | startsWith | regex
  matchValue  String
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  setReviewed Boolean   @default(false)
  addTags     String?  // comma-separated tag names
  sortOrder   Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TransactionSplit {
  id            String    @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  amount        Float
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([transactionId])
}

model Budget {
  id           String   @id @default(cuid())
  category     String?  @unique // category name (kept for back-compat; new budgets also set categoryId)
  categoryId   String?  // link to Category model
  categoryRef  Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  monthlyLimit Float
  rollover     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([categoryId])
}

model Bill {
  id             String    @id @default(cuid())
  name           String
  amount         Float
  dueDay         Int // day of month, 1-31 (used for monthly manual bills / back-compat)
  category       String?
  isAutoDetected Boolean   @default(false)
  active         Boolean   @default(true)
  accountId      String?
  account        Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  lastPaidDate   DateTime?
  // ---- Phase 2: recurring-bill scheduling + auto-detection ----
  frequency      String?  // weekly | biweekly | monthly | quarterly | annual
  nextDueDate    DateTime? // primary scheduling field (overrides dueDay when set)
  lastAmount     Float?    // most recent occurrence amount (for variable bills)
  avgAmount      Float?    // rolling average amount
  type           String?  // bill | subscription
  confidence     Float?    // detection confidence 0..1 (null for manual bills)
  sourceNames    String?  // JSON array of matched transaction names (traceability)
  autoDetectedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([active])
  @@index([nextDueDate])
}

// Static-ish reference table of credit card products used by the
// recommendation engine. Seeded from a curated JSON dataset (see lib/creditCards.ts).
// This is informational only — not personalized financial advice.
model CreditCardOption {
  id           String   @id @default(cuid())
  issuer       String
  name         String
  annualFee    Float    @default(0)
  rewardsJson  String // JSON-encoded map of category -> reward rate (e.g. {"dining":3,"groceries":2,"other":1})
  signupBonus  String?
  notes        String?
  applyUrl     String?
  createdAt    DateTime @default(now())
}

model NetWorthSnapshot {
  id              String   @id @default(cuid())
  date            DateTime @default(now())
  totalAssets     Float
  totalLiabilities Float
  netWorth        Float

  @@index([date])
}


// ---- Phase 3: Goals (savings + debt payoff) ----
model Goal {
  id                  String    @id @default(cuid())
  name                String
  type                String    @default("savings") // savings | debt
  targetAmount        Float     // savings target; for debt, the target balance (usually 0)
  currentAmount       Float     @default(0) // manual current amount / manual debt balance fallback
  startingAmount      Float?    // snapshot for progress math
  targetDate          DateTime? // optional target completion date
  monthlyContribution Float?    // savings contribution or debt payment
  linkedAccountId     String?  // optional: savings account (auto-track) or debt account (live balance)
  linkedAccount       Account?  @relation(fields: [linkedAccountId], references: [id], onDelete: SetNull)
  interestRate        Float?    // APR percent (e.g. 24.99), for debt payoff
  active              Boolean   @default(true)
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([type])
  @@index([linkedAccountId])
  @@index([active])
}


// ---- Phase 4: Manual assets & liabilities (property, vehicles, crypto, other) ----
model Asset {
  id          String   @id @default(cuid())
  name        String
  category    String   // property | vehicle | crypto | cash | other_asset | mortgage | loan | other_liability
  isLiability Boolean  @default(false)
  value       Float    // estimated market value; for liabilities, the amount owed (positive)
  quantity    Float?   // crypto units (optional)
  ticker      String?  // symbol (crypto/stock) for future price fetch
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isLiability])
}
