# --- Database (Railway Postgres plugin provides this automatically) ---
DATABASE_URL="postgresql://user:password@host:5432/railway"

# --- App auth (personal single-user password gate) ---
APP_PASSWORD="choose-a-strong-password"
SESSION_SECRET="generate-a-random-32-char-string"

# --- Plaid (sign up free at https://dashboard.plaid.com/signup, use Sandbox keys to start) ---
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"
